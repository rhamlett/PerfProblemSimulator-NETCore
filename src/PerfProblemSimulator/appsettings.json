{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "PerfProblemSimulator": "Warning"
    },
    "ApplicationInsights": {
      "LogLevel": {
        "Default": "Warning",
        "PerfProblemSimulator": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ProblemSimulator": {
    "MetricsCollectionIntervalMs": 250,
    "LatencyProbeIntervalMs": 200
  }
}
